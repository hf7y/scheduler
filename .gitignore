# Generated backups of the live crontab (bin/sync-crontab.sh --apply)
.crontab-backups/

# Machine-specific symlinks into each project's real .claude/QUESTIONS.md,
# regenerated by bin/sync-crontab.sh --apply. The dir is tracked (.gitkeep),
# the links are not.
questions/*.md
!questions/.gitkeep

# Same for focus/ -- symlinks into each project's real .claude/FOCUS.md,
# regenerated by bin/sync-crontab.sh --apply. Dir tracked, links not.
focus/*.md
!focus/.gitkeep

# Generated + machine-specific (symlinks) audit view, rebuilt by
# bin/build-services-view.sh. The generator is tracked; its output is not.
services/*
!services/.gitkeep

# Stray captured report output that landed in bin/ -- not source.
bin/morning-report.md

# Generated by bin/morning-report.sh every run -- the compiled cross-
# project digest (reports + questions + blockers), not source.
DIGEST.md
