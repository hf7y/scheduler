# Schedule entry template -- copy to ../schedule/<project>.conf, fill in,
# then run ../bin/sync-crontab.sh (prints a preview; add --apply to
# actually write it) to install/update this project's crontab lines.
#
# ONE FILE per project. This conf is the single source of truth for both
# *when* each job fires (the scheduling fields) and *how* it runs (the
# runtime fields) -- ../bin/scheduler-run reads the runtime fields and
# sources ../lib/sweep-loop-common.sh, so there is no separate per-project
# wrapper script to write or keep in sync.
#
# "Registering" a project IS this: drop a file here with real values, run
# bin/sync-crontab.sh --apply. Deregistering is deleting this file and
# running sync again.
#
# Two registries, don't conflate (see README):
#   - THIS file = the config-time "which hours does this project run"
#     registry.
#   - lib/sweep-loop-common.sh's ~/.local/share/scheduler-registry/ =
#     the runtime PROJECT_KEY mutex that stops a project's own Tier 1 and
#     Tier 2 from racing each other's git push if both are already running.

PROJECT="<project-name>"

# Optional -- this project's real working copy, if it has one. Used to
# symlink its .claude/QUESTIONS.md into ../questions/<project>.md and its
# .claude/FOCUS.md into ../focus/<project>.md (sync-crontab.sh --apply
# creates the QUESTIONS.md file with a template header first if missing).
# Leave blank for a project with no local working copy in this shape.
PROJECT_REPO_PATH="/home/zach/Documents/Project Archive/<project>"

# ===========================================================================
# RUNTIME CONFIG (read by bin/scheduler-run; ignored for a tier that still
# sets a legacy *_SCRIPT below).
# ===========================================================================

# Short, unique PER PROJECT (not per tier). A project's Tier 1 and Tier 2
# share this key -- that's what lets them detect and skip around each other.
# Defaults to PROJECT if left blank.
PROJECT_KEY="<project-name>"

# git clone URL (SSH -- cron has no ssh-agent, so use a passphrase-less
# per-repo deploy key + a ~/.ssh/config host alias) for the dedicated,
# disposable clone the job runs in.
REPO_URL="git@github-<project>-deploy:<owner>/<repo>.git"

# Subdirectory within the clone to cd into before invoking claude. "." if
# the project IS the repo root.
REPO_SUBDIR="."

# Optional -- a local dir of non-git secrets (tokens, keypairs) gitignored
# by design, copied into the clone every run so a fresh clone still has
# them. Leave blank/omit to disable.
# SECRETS_SRC_DIR="/home/zach/Documents/Project Archive/<project>/.session-handoff"
# SECRETS_DEST_SUBDIR=".session-handoff"

# ===========================================================================
# TIER 1 -- bug sweeper. Leave SWEEP_JOB_NAME blank to skip this tier.
# ===========================================================================

SWEEP_JOB_NAME="<project>-bug-sweep"   # names this job's state/expiry dir
                                         # (~/.local/share/$SWEEP_JOB_NAME)
SWEEP_CRON="*/15 9-21 * * *"           # fixed daytime window -- fill in real
                                         # hours, don't ship the placeholder

# --- new-style runtime config (used when SWEEP_SCRIPT is blank) ---
SWEEP_PROMPT="/bug-sweep

This is a fully unattended run with no human review step. Commit and push
your fixes yourself. Never resolve or reclassify a report you are not
confident about; leave it open with a note instead."
SWEEP_MAX_TURNS=40
# SWEEP_MODEL="claude-sonnet-5"                       # cheaper model for a mechanical sweep
# SWEEP_PRECHECK_CMD="/home/zach/.local/bin/<project>-bug-sweep-precheck.sh"
# SWEEP_ALLOWED_TOOLS="Bash,Read,Write,Edit,Glob,Grep"
# SWEEP_EXPIRY_DAYS=7
# SWEEP_BRANCH="main"

# --- LEGACY (backwards-compat): if set, this wins and the runtime fields
# above are ignored for Tier 1. Drop it to migrate onto scheduler-run. ---
# SWEEP_SCRIPT="/home/zach/.local/bin/<project>-bug-sweep-loop.sh"

# ===========================================================================
# TIER 2 -- overnight batch. Leave BATCH_JOB_NAME blank to skip this tier.
# ===========================================================================

BATCH_JOB_NAME="<project>-nightly-batch"
BATCH_CRON="auto"                       # "auto" (or blank) lets sync-crontab.sh
                                         # assign a staggered slot (see
                                         # schedule/_batch.conf). Set an explicit
                                         # "MIN HOUR * * *" only if this project's
                                         # cadence genuinely isn't nightly.

# --- new-style runtime config (used when BATCH_SCRIPT is blank) ---
BATCH_PROMPT="/nightly-batch

This is a fully unattended overnight run. Read .claude/FOCUS.md FIRST --
everything tonight is scoped by it. Write your report to
~/reports/<project>/\$(date +%Y-%m-%d).md and update
~/reports/<project>/LATEST.md to match. Confirm everything is committed and
pushed before finishing."
BATCH_MAX_TURNS=200
# BATCH_MODEL="claude-opus-4-8"
# BATCH_PRECHECK_CMD="..."
# BATCH_ALLOWED_TOOLS="Bash,Read,Write,Edit,Glob,Grep"
# BATCH_EXPIRY_DAYS=7
# BATCH_BRANCH="main"

# --- LEGACY (backwards-compat): drop to migrate onto scheduler-run. ---
# BATCH_SCRIPT="/home/zach/.local/bin/<project>-nightly-batch-loop.sh"
