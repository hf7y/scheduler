#!/usr/bin/env bash
# scheduler -- quick navigation into the scheduler's own tracking files, so
# "what's going on / what needs me" doesn't require hunting through nested
# project folders. No args = one-screen glance; subcommands jump straight
# into a file in $EDITOR (vim if unset). Read-only glance, editor commands
# open real files (or symlinks into each project's real .claude/ files) --
# this is a thin wrapper, not a parser/database; see
# .claude/scheduler/FOCUS.md item 3 for the fuller "glance command" design
# this is a first cut of.
set -uo pipefail

SCHED_ROOT="/home/zach/Documents/Project Archive/scheduler"
REPORTS_ROOT="$HOME/reports"
EDITOR="${EDITOR:-vim}"

usage() {
  cat <<'EOF'
usage: scheduler [command] [project]

  (no args)             one-screen glance: every registered project, open
                         question count, and whether BLOCKERS.md has an
                         entry for it
  blockers, -b          open BLOCKERS.md
  focus [project], -f   open a project's FOCUS.md (list projects if omitted)
  questions [project], -q
                         open a project's QUESTIONS.md (list if omitted)
  report [project], -r  open a project's latest report (LATEST.md)
  idea <project> "text", -i
                         drop a new idea/feature-request for a project
                         without opening an editor. realisateur gets a new
                         .idea file (its own real inbox convention); every
                         other project gets a timestamped line inserted
                         into its FOCUS.md backlog/feature-request section
                         (or a new "Ideas" section, created if the project
                         has no FOCUS.md yet)
  sweep, -s              reactive backstop for the vim auto-commit hook --
                         scans every registered repo (+ scheduler itself)
                         for uncommitted/unpushed/diverged state the hook
                         may have missed (e.g. a long-running vim session
                         that predates a ~/.vimrc change never fires new
                         autocmds). Safely auto-commits dirty *.md files
                         one at a time (same tested logic as `-i`); never
                         touches non-.md files or attempts to resolve a
                         genuine ahead+behind divergence -- those are only
                         ever reported, never auto-resolved.
  status <project>, -c  offline (no AI) deep-dive on one project: git
                         health (dirty/ahead/behind/diverged, + dedicated
                         clone divergence), pending %%TAG/`> ` feedback
                         (via collect-feedback.sh), open QUESTIONS.md
                         entries, and the last scheduled run's outcome
                         from its log. Append --claude for a one-shot
                         read-only `claude -p` narrated summary of the
                         same report, or --interactive (-I) to drop into
                         a live `claude` session in the project's repo
                         preloaded with it as starting context.

Examples: scheduler -b   |   scheduler focus crt   |   scheduler report wtul
          scheduler -i realisateur "a browser extension that ..."
          scheduler -i wtul "add a --dry-run flag to wtul-rip"
          scheduler -s
          scheduler status realisateur
          scheduler status realisateur --claude
          scheduler status realisateur --interactive
EOF
}

projects() {
  for conf in "$SCHED_ROOT"/schedule/*.conf; do
    b="$(basename "$conf" .conf)"
    [[ "$b" == _* ]] && continue
    echo "$b"
  done
}

open_file() {
  local path="$1"
  if [ ! -e "$path" ]; then
    echo "scheduler: no file yet at $path" >&2
    exit 1
  fi
  exec "$EDITOR" "$path"
}

require_project() {
  local kind="$1" proj="${2:-}"
  if [ -z "$proj" ]; then
    echo "available projects:"
    projects | sed 's/^/  /'
    echo
    echo "usage: scheduler $kind <project>"
    exit 1
  fi
}

conf_field() {
  local proj="$1" field="$2" conf="$SCHED_ROOT/schedule/$proj.conf"
  [ -f "$conf" ] || return 1
  grep -E "^${field}=" "$conf" | head -1 | cut -d= -f2- | tr -d '"'
}

resolve_focus_path() {
  local proj="$1"
  local repo_path subdir
  repo_path="$(conf_field "$proj" PROJECT_REPO_PATH)"
  if [ -z "$repo_path" ]; then
    echo "scheduler: no such project '$proj', or it has no PROJECT_REPO_PATH set" >&2
    return 1
  fi
  subdir="$(conf_field "$proj" SCHEDULER_SUBDIR)"
  echo "$repo_path/${subdir:-.claude}/FOCUS.md"
}

cmd_idea() {
  local proj="${1:-}" text="${2:-}"
  if [ -z "$proj" ] || [ -z "$text" ]; then
    echo "usage: scheduler idea <project> \"idea text\""
    echo
    echo "available projects:"
    projects | sed 's/^/  /'
    exit 1
  fi

  if [ "$proj" = "realisateur" ]; then
    local repo_path
    repo_path="$(conf_field realisateur PROJECT_REPO_PATH)"
    if [ -z "$repo_path" ]; then
      echo "scheduler: realisateur has no PROJECT_REPO_PATH set" >&2
      exit 1
    fi
    local slug ts file
    ts="$(date +%Y%m%d-%H%M%S)"
    slug="$(printf '%s' "$text" | tr -c 'a-zA-Z0-9' '-' | tr -s '-' | cut -c1-30 | sed 's/^-*//; s/-*$//')"
    [ -n "$slug" ] || slug="idea"
    file="$repo_path/${slug}-${ts}.idea"
    printf '%s\n' "$text" > "$file"
    echo "dropped: $file"
    echo "(realisateur's own inbox convention -- picked up + archived by its next nightly-batch cycle)"
    cmd_commit_file "$file" "Idea added via \`scheduler -i\`: $(basename "$file")"
    return
  fi

  local focus_path
  focus_path="$(resolve_focus_path "$proj")" || exit 1
  local ts="$(date '+%Y-%m-%d %H:%M')"
  local line="- **$ts (via \`scheduler -i\`):** $text"

  if [ ! -f "$focus_path" ]; then
    mkdir -p "$(dirname "$focus_path")"
    {
      echo "<!-- Per-project scope marker -- this file was CREATED by"
      echo "     \`scheduler -i\` from a dropped idea. It's just that idea,"
      echo "     not a real scope doc yet -- flesh this out properly, or at"
      echo "     least confirm it before the next unattended run treats it"
      echo "     as gospel. -->"
      echo
      echo "## Ideas (added via \`scheduler -i\`)"
      echo
      echo "$line"
    } > "$focus_path"
    echo "created: $focus_path"
    cmd_commit_file "$focus_path" "Idea added via \`scheduler -i\`: $(basename "$focus_path")"
    return
  fi

  if awk -v IGNORECASE=1 '/^#+.*(backlog|feature request)/{f=1} END{exit !f}' "$focus_path"; then
    awk -v IGNORECASE=1 -v line="$line" '
      { print }
      !done && /^#+.*(backlog|feature request)/ { print ""; print line; done=1 }
    ' "$focus_path" > "$focus_path.tmp" && mv "$focus_path.tmp" "$focus_path"
    echo "inserted into backlog/feature-request section: $focus_path"
  else
    {
      echo
      echo "## Ideas (added via \`scheduler -i\`)"
      echo
      echo "$line"
    } >> "$focus_path"
    echo "appended new section to: $focus_path"
  fi
  cmd_commit_file "$focus_path" "Idea added via \`scheduler -i\`: $(basename "$focus_path")"
}

cmd_commit_file() {
  # THE single implementation of "safely auto-commit one file, with a
  # staleness warning first" -- shared by `scheduler -i` (calls this
  # directly, in-process) AND the vim auto-commit hook (shells out to
  # `scheduler _commit-file`, backgrounded, instead of re-implementing
  # this same git logic a second time in vimscript). Change behavior
  # here once, both callers get it. (Renamed from cmd_idea_push_reminder
  # 2026-07-20 when this stopped being idea-specific.)
  #
  # Auto-COMMITS (never auto-pushes -- push always stays a human step).
  # This project's scheduled jobs run against a dedicated clone that
  # resets hard to origin before every dispatch, so a file sitting merely
  # committed-but-unpushed is exactly as invisible to it as an
  # uncommitted one -- only the commit step was the one people (and
  # agents) kept forgetting.
  local path="$1" msg="${2:-}" repo
  repo="$(git -C "$(dirname "$path")" rev-parse --show-toplevel 2>/dev/null)"
  [ -n "$repo" ] || return 0
  # `git diff --quiet` only sees changes to ALREADY-TRACKED files -- it is
  # silent (exit 0, "no differences") for a brand-new untracked file, which
  # made this bail out and skip committing entirely for exactly the case
  # (a freshly dropped .idea file) it most needed to handle. `git status
  # --porcelain` catches both untracked and modified.
  if [ -z "$(git -C "$repo" status --porcelain -- "$path" 2>/dev/null)" ]; then
    return 0
  fi
  # Freshness check BEFORE committing -- the actual fix for "do I need to
  # git fetch && git status by hand before every edit" (2026-07-20): no,
  # the tool checks instead. Doesn't block the commit (the file content is
  # always safe to keep locally regardless), just warns loudly if this
  # commit is about to land on a stale base, which is exactly the failure
  # mode that caused a real divergence (home-assistant, same day). `git
  # fetch` against a local bare remote (~/git-remotes/*.git, most projects
  # here) is effectively instant; against a real GitHub remote it's a
  # normal network round-trip -- worth it for what it catches.
  local branch behind
  branch="$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)"
  git -C "$repo" fetch --quiet 2>/dev/null
  behind="$(git -C "$repo" rev-list --count "HEAD..origin/$branch" 2>/dev/null || echo 0)"
  if [ "${behind:-0}" -gt 0 ] 2>/dev/null; then
    echo "NOTE: $repo is $behind commit(s) behind origin/$branch -- committing anyway (your edit is safe), but pull/merge before pushing to avoid a real divergence"
  fi
  [ -n "$msg" ] || msg="Human edit via scheduler: $(basename "$path") ($(date '+%Y-%m-%dT%H:%M'))"
  if git -C "$repo" add -- "$path" && git -C "$repo" commit -q -m "$msg" -- "$path"; then
    echo "committed locally in $repo -- run 'git -C \"$repo\" push' whenever you're ready (never automatic)"
  else
    echo "(auto-commit failed -- left as an uncommitted edit at $path; commit by hand)" >&2
  fi
}

cmd_glance() {
  echo "scheduler — $(date '+%Y-%m-%d %H:%M') (paced rotation, dispatched whenever usage-gate.sh has spare quota)"
  echo
  printf '  %-16s %-9s %s\n' "PROJECT" "QUESTIONS" "BLOCKERS.md"
  local any_blockers=0
  while IFS= read -r proj; do
    local qfile="$SCHED_ROOT/questions/$proj.md"
    local qlabel="-"
    if [ -f "$qfile" ]; then
      # Distinguishes genuinely unanswered questions from ones you've
      # already replied to inline but the project's next run hasn't yet
      # processed -- added 2026-07-20 so the glance count reflects your
      # own inline edits instead of only updating once a run clears the
      # block. A bullet counts as answered if a real `> ` reply (not the
      # "(answer inline here)" placeholder) appears before the next
      # bullet/heading; RESOLVED/ACKNOWLEDGED bullets are excluded
      # entirely either way (case-insensitive via tolower(), not just
      # the first letter -- a plain-ASCII "resolved|acknowledged" regex
      # match silently missed full-caps "RESOLVED" during testing).
      read -r q_unanswered q_answered <<<"$(awk '
        BEGIN{unanswered=0; answered=0; is_resolved=0; has_reply=0; started=0}
        /^- \*\*/ {
          if (started) { if (!is_resolved) { if (has_reply) answered++; else unanswered++ } }
          started=1
          is_resolved = (tolower($0) ~ /resolved|acknowledged/) ? 1 : 0
          has_reply=0
          next
        }
        started && /^[ \t]*>[ \t]?/ {
          line=$0
          sub(/^[ \t]*>[ \t]?/, "", line)
          if (line !~ /^\(answer inline here\)/) has_reply=1
        }
        END { if (started) { if (!is_resolved) { if (has_reply) answered++; else unanswered++ } }
              print unanswered, answered }
      ' "$qfile" 2>/dev/null)"
      q_unanswered="${q_unanswered:-0}"; q_answered="${q_answered:-0}"
      if [ "$q_unanswered" -gt 0 ] 2>/dev/null; then
        qlabel="$q_unanswered open"
        [ "$q_answered" -gt 0 ] 2>/dev/null && qlabel="$qlabel (+$q_answered✓)"
      elif [ "$q_answered" -gt 0 ] 2>/dev/null; then
        qlabel="0 open ($q_answered✓ pending run)"
      fi
    fi

    local bn=0
    [ -f "$SCHED_ROOT/BLOCKERS.md" ] && bn="$(awk -v want="$proj" '
      BEGIN{c=0; insec=0}
      /^##[ \t]/ { insec = (tolower($0) ~ ("## *" tolower(want) "$")); next }
      insec && /^- \*\*/ { c++ }
      END { print c }
    ' "$SCHED_ROOT/BLOCKERS.md")"
    local blabel="-"
    if [ "$bn" -gt 0 ] 2>/dev/null; then
      blabel="$bn"
      any_blockers=1
    fi

    printf '  %-16s %-9s %s\n' "$proj" "$qlabel" "$blabel"
  done < <(projects)
  echo
  if [ "$any_blockers" = "1" ]; then
    echo "-> scheduler blockers   (or: scheduler -b)"
  fi
  echo "-> scheduler focus/questions/report <project> to jump straight in"
}

report_divergence() {
  # Shared by cmd_sweep and cmd_status -- reports (never resolves) how a
  # local branch stands vs its origin. Split out 2026-07-22 so the status
  # deep-dive doesn't reimplement this same ahead/behind/diverged check.
  local name="$1" path="$2"
  local branch ahead behind
  branch="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null)"
  ahead="$(git -C "$path" rev-list --count "origin/$branch..HEAD" 2>/dev/null || echo 0)"
  behind="$(git -C "$path" rev-list --count "HEAD..origin/$branch" 2>/dev/null || echo 0)"
  if [ "${ahead:-0}" -gt 0 ] 2>/dev/null && [ "${behind:-0}" -gt 0 ] 2>/dev/null; then
    echo "== $name: ** DIVERGED from origin/$branch ** -- $ahead local-only, $behind remote-only commit(s). Needs a real merge decision -- NOT auto-resolved, ever."
  elif [ "${ahead:-0}" -gt 0 ] 2>/dev/null; then
    echo "== $name: $ahead commit(s) ahead of origin/$branch, not pushed (push always stays a human step)"
  elif [ "${behind:-0}" -gt 0 ] 2>/dev/null; then
    echo "== $name: $behind commit(s) behind origin/$branch"
  fi
}

cmd_sweep() {
  echo "scheduler sweep -- $(date '+%Y-%m-%d %H:%M')"
  echo "(reactive backstop: catches uncommitted/unpushed/diverged state the vim"
  echo " auto-commit hook may have missed -- e.g. a long-running vim session"
  echo " that predates a ~/.vimrc change never picks up new autocmds)"
  echo

  local repos_seen=0 issues_found=0
  {
    printf 'scheduler|%s\n' "$SCHED_ROOT"
    while IFS= read -r proj; do
      # scheduler is also self-registered (schedule/scheduler.conf, for its
      # own dogfooded paced cycle) -- already covered by the hardcoded line
      # above, skip here to avoid checking the same repo twice.
      [ "$proj" = "scheduler" ] && continue
      local rp
      rp="$(conf_field "$proj" PROJECT_REPO_PATH)"
      [ -n "$rp" ] && printf '%s|%s\n' "$proj" "$rp"
    done < <(projects)
  } | while IFS='|' read -r name path; do
    [ -d "$path/.git" ] || continue
    repos_seen=$((repos_seen + 1))

    # Safe .md files get auto-committed, one file at a time, same tested
    # logic `-i` already uses. Anything else (code, YAML config, etc.) is
    # only ever reported -- see home-assistant's config/automations.yaml
    # divergence (2026-07-20) for exactly why this stays conservative.
    local dirty_md
    dirty_md="$(git -C "$path" status --porcelain -- '*.md' 2>/dev/null | awk '{print $2}')"
    if [ -n "$dirty_md" ]; then
      while IFS= read -r rel; do
        [ -n "$rel" ] || continue
        echo "== $name: auto-committing $rel =="
        cmd_commit_file "$path/$rel"
      done <<< "$dirty_md"
    fi

    local dirty_other
    dirty_other="$(git -C "$path" status --porcelain -- . ':!*.md' 2>/dev/null)"
    if [ -n "$dirty_other" ]; then
      echo "== $name: dirty, NOT auto-committed (only *.md is safe to auto-commit) =="
      echo "$dirty_other" | sed 's/^/  /'
    fi

    report_divergence "$name" "$path"
  done

  # Second pass: every automated job's DEDICATED CLONE
  # (~/.local/share/<JOB_NAME>/repo) -- added 2026-07-20 after realizing
  # the first pass above only ever checks YOUR manual checkouts. That's a
  # real blind spot: the original stranded-commit incident this whole
  # feature exists for (chezz, same day) was found sitting in a dedicated
  # clone, not a human checkout -- the first version of `sweep` could
  # never have caught its own motivating example. Glob-based, not
  # conf-parsed: scans whatever actually exists under ~/.local/share/*/repo
  # rather than trying to reconstruct job names from schedule/*.conf,
  # so it also covers legacy per-tier clones (chezz-bug-sweep,
  # chezz-nightly-batch, etc.) without needing to keep two enumeration
  # paths in sync. Scheduler's own jobs use throwaway worktrees, not this
  # shape (confirmed: no matching repo/ dir), so they're naturally excluded,
  # not special-cased.
  #
  # REPORT ONLY here, never auto-commit -- a dedicated clone gets a fresh
  # `git reset --hard origin/<branch>` before every run, so a human is
  # never expected to be editing inside one directly. Anything dirty or
  # unpushed there is either a genuinely interrupted run (the exact thing
  # worth surfacing) or something unusual enough to deserve a look, not a
  # routine auto-commit that could paper over what actually happened.
  local clone_found=0
  for repo in "$HOME"/.local/share/*/repo; do
    [ -d "$repo/.git" ] || continue
    clone_found=1
    job="$(basename "$(dirname "$repo")")"
    dirty="$(git -C "$repo" status --porcelain 2>/dev/null)"
    branch="$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null)"
    ahead="$(git -C "$repo" rev-list --count "origin/$branch..HEAD" 2>/dev/null || echo 0)"
    if [ -n "$dirty" ]; then
      echo "== [clone] $job: dirty in the dedicated clone itself -- unusual, worth a look =="
      echo "$dirty" | sed 's/^/  /'
    fi
    if [ "${ahead:-0}" -gt 0 ] 2>/dev/null; then
      echo "== [clone] $job: $ahead commit(s) ahead of origin/$branch, sitting UNPUSHED in the dedicated clone -- likely a run that got cut off after committing but before pushing (see the stranded-commit backlog item) =="
    fi
  done

  echo
  if [ "$clone_found" = "1" ]; then
    echo "swept every registered project + scheduler itself + every job's dedicated clone."
  else
    echo "swept every registered project + scheduler itself. (no dedicated clones found under ~/.local/share/*/repo)"
  fi
}

build_status_report() {
  # All plain bash/awk/git -- no `claude` invocation. This is the entire
  # point of `scheduler status`: the common "how's <project> doing" check
  # should cost zero tokens by default. cmd_status prints this directly;
  # --claude/--interactive just layer an AI step on top of the same text.
  local proj="$1" repo_path="$2" job_name="$3"

  echo "scheduler status: $proj -- $(date '+%Y-%m-%d %H:%M')"

  echo
  echo "-- git health ($repo_path) --"
  if [ -d "$repo_path/.git" ]; then
    local dirty divergence
    dirty="$(git -C "$repo_path" status --porcelain 2>/dev/null)"
    if [ -n "$dirty" ]; then
      echo "dirty:"
      echo "$dirty" | sed 's/^/  /'
    fi
    divergence="$(report_divergence "$proj" "$repo_path")"
    [ -n "$divergence" ] && printf '%s\n' "$divergence"
    [ -z "$dirty" ] && [ -z "$divergence" ] && echo "clean, up to date with origin"
  else
    echo "not a git repo (or PROJECT_REPO_PATH is missing on disk)"
  fi

  if [ -n "$job_name" ] && [ -d "$HOME/.local/share/$job_name/repo/.git" ]; then
    echo
    echo "-- dedicated clone vs working checkout --"
    local clone_head repo_head
    clone_head="$(git -C "$HOME/.local/share/$job_name/repo" rev-parse HEAD 2>/dev/null)"
    repo_head="$(git -C "$repo_path" rev-parse HEAD 2>/dev/null)"
    if [ -n "$clone_head" ] && [ "$clone_head" != "$repo_head" ]; then
      echo "clone HEAD ($clone_head) != working checkout HEAD ($repo_head) -- normal if you've committed locally since the clone's last dispatch; only a concern if the CLONE is ahead (that would mean a stranded commit -- see 'scheduler sweep')"
    else
      echo "clone matches working checkout HEAD"
    fi
  fi

  echo
  echo "-- pending feedback (collect-feedback.sh) --"
  local fb="" bb=""
  [ -f "$REPORTS_ROOT/$proj/LATEST.md" ] && fb="$("$SCHED_ROOT/bin/collect-feedback.sh" "$REPORTS_ROOT/$proj/LATEST.md" 2>/dev/null)"
  [ -f "$SCHED_ROOT/BLOCKERS.md" ] && bb="$("$SCHED_ROOT/bin/collect-feedback.sh" "$SCHED_ROOT/BLOCKERS.md" --section "$proj" 2>/dev/null)"
  if [ -z "$fb" ] && [ -z "$bb" ]; then
    echo "none pending"
  else
    [ -n "$fb" ] && printf '%s\n' "$fb"
    [ -n "$bb" ] && printf '%s\n' "$bb"
  fi

  echo
  echo "-- open questions ($SCHED_ROOT/questions/$proj.md) --"
  local qfile="$SCHED_ROOT/questions/$proj.md"
  if [ -f "$qfile" ]; then
    # Same unanswered/resolved logic as cmd_glance's awk block, but prints
    # the actual bullet text instead of just a count -- a deep-dive on one
    # project should show you the question, not send you to go open it.
    local unanswered
    unanswered="$(awk '
      function flush() { if (started && !is_resolved && !has_reply) print buf }
      /^- \*\*/ {
        flush()
        started=1
        is_resolved = (tolower($0) ~ /resolved|acknowledged/) ? 1 : 0
        has_reply=0; buf=$0
        next
      }
      started && /^[ \t]*>[ \t]?/ {
        line=$0
        sub(/^[ \t]*>[ \t]?/, "", line)
        if (line !~ /^\(answer inline here\)/) has_reply=1
      }
      END { flush() }
    ' "$qfile")"
    if [ -n "$unanswered" ]; then
      printf '%s\n' "$unanswered"
    else
      echo "none open"
    fi
  else
    echo "no QUESTIONS.md symlink found"
  fi

  echo
  echo "-- last scheduled run ($job_name) --"
  local log="$HOME/.local/share/$job_name/sweep.log"
  if [ -n "$job_name" ] && [ -f "$log" ]; then
    local expires
    if [ -f "$HOME/.local/share/$job_name/expires_at" ]; then
      expires="$(cat "$HOME/.local/share/$job_name/expires_at")"
      if [[ "$(date -Is)" > "$expires" ]]; then
        echo "EXPIRED $expires -- auto-disabled, needs EXPIRY_DAYS bump + bin/sync-crontab.sh to renew"
      else
        echo "expires: $expires"
      fi
    fi
    grep -E '^=== (done|FAILED|skipped)' "$log" | tail -1
    grep '^pushed:' "$log" | tail -1
    grep '^WARNING: local commit made but NOT pushed' "$log" | tail -1
  else
    echo "no log yet at $log"
  fi
}

cmd_status() {
  local proj="$1" mode="${2:-}"
  case "$mode" in
    ""|--claude|--interactive|-I) ;;
    *) echo "scheduler: unknown status flag '$mode' (use --claude or --interactive)" >&2; exit 2 ;;
  esac

  local repo_path
  repo_path="$(conf_field "$proj" PROJECT_REPO_PATH)"
  if [ -z "$repo_path" ]; then
    echo "scheduler: no such project '$proj', or it has no PROJECT_REPO_PATH set" >&2
    exit 1
  fi

  local job_name
  job_name="$(conf_field "$proj" BATCH_JOB_NAME)"
  [ -n "$job_name" ] || job_name="$(conf_field "$proj" SWEEP_JOB_NAME)"

  local report
  report="$(build_status_report "$proj" "$repo_path" "$job_name")"
  printf '%s\n' "$report"

  case "$mode" in
    --claude)
      echo
      echo "--- claude summary (read-only, --allowedTools Read,Grep,Glob) ---"
      (cd "$repo_path" && claude -p "$(cat <<EOF
Here is an offline status report for the "$proj" project, generated by
plain scripts (git status, pending human-feedback tags, open questions,
last automated run's log) -- no code was read yet.

$report

Skim the project's own README/FOCUS.md if useful, then write a short
(5 bullets max) human-readable status note: what's actually going on,
anything that looks off or needs attention, anything safe to ignore.
EOF
)" --allowedTools "Read,Grep,Glob" --max-turns 15)
      ;;
    --interactive|-I)
      echo
      echo "launching interactive claude session in $repo_path, preloaded with the report above..."
      cd "$repo_path" || exit 1
      exec claude "$report

Use this as your starting context for looking into $proj -- feel free to dig into the actual code/repo from here."
      ;;
  esac
}

case "${1:-}" in
  ""|glance) cmd_glance ;;
  blockers|-b) open_file "$SCHED_ROOT/BLOCKERS.md" ;;
  focus|-f)
    require_project focus "${2:-}"
    open_file "$SCHED_ROOT/focus/$2.md"
    ;;
  questions|-q)
    require_project questions "${2:-}"
    open_file "$SCHED_ROOT/questions/$2.md"
    ;;
  report|-r)
    require_project report "${2:-}"
    open_file "$REPORTS_ROOT/$2/LATEST.md"
    ;;
  idea|-i) cmd_idea "${2:-}" "${3:-}" ;;
  _commit-file)
    # Internal, not a documented user-facing verb (leading underscore
    # matches the schedule/_*.conf "meta, not a project" convention) --
    # the vim auto-commit hook's own entrypoint into cmd_commit_file, so
    # there's exactly one implementation of "safely commit one file with
    # a staleness check" for both callers to share.
    cmd_commit_file "${2:-}" "${3:-}"
    ;;
  sweep|-s) cmd_sweep ;;
  status|-c)
    require_project status "${2:-}"
    cmd_status "$2" "${3:-}"
    ;;
  -h|--help|help) usage ;;
  *) echo "scheduler: unknown command '$1'" >&2; usage; exit 2 ;;
esac
